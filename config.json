{
  "_comment": "Equity Research Assistant — Master Config. Edit this file to customize everything.",
  "schedule": {
    "cron": "0 19 * * 1-5",
    "timezone": "Asia/Kolkata",
    "_note": "6PM IST on weekdays. Change to '0 9 * * 1-5' for 9AM pre-market."
  },
  "stocks": {
    "india_nse": [
      "RELIANCE.NS",
      "TCS.NS",
      "INFY.NS",
      "ICICIBANK.NS",
      "HINDUNILVR.NS",
      "MARUTI.NS",
      "APOLLOHOSP.NS",
      "DIVISLAB.NS",
      "IRFC.NS",
      "ADANIENT.NS",
      "BPCL.NS",
      "GOLDBEES.NS",
      "GAIL.NS",
      "HDFCBANK.NS",
      "IOC.NS",
      "JIOFIN.NS",
      "LTFOODS.NS",
      "MHRIL.NS",
      "SETFGOLD.NS",
      "NCC.NS",
      "RAJESHEXPO.NS",
      "TATACAP.NS",
      "TMPV.NS",
      "DMART.NS"
    ],
    "india_bse": [],
    "us_stocks": [],
    "_note": "Add .NS for NSE, .BO for BSE, no suffix for US. Leave arrays empty to skip."
  },
  "scoring_weights": {
    "technical": 0.45,
    "volume": 0.25,
    "event": 0.15,
    "fundamental": 0.15,
    "_note": "Must sum to 1.0. Increase technical weight for pure TA traders."
  },
  "signal_thresholds": {
    "strong_buy": 72,
    "buy": 58,
    "neutral_low": 42,
    "sell": 28,
    "_note": "Composite score cutoffs. Raise strong_buy to 80 for stricter filtering."
  },
  "indicator_params": {
    "rsi_period": 14,
    "macd_fast": 12,
    "macd_slow": 26,
    "macd_signal": 9,
    "bb_period": 20,
    "bb_std_dev": 2,
    "atr_period": 14,
    "stoch_period": 14,
    "stoch_smooth": 3,
    "cci_period": 20,
    "adx_period": 14,
    "cmf_period": 20,
    "mfi_period": 14,
    "supertrend_period": 10,
    "supertrend_mult": 3.0,
    "volume_spike_ratio": 1.5,
    "_note": "All indicator lookback periods and multipliers."
  },
  "rsi_zones": {
    "overbought": 70,
    "bullish_min": 55,
    "neutral_min": 45,
    "bearish_min": 30,
    "_note": "RSI signal zone boundaries."
  },
  "scoring_rules": {
    "rsi_bullish_zone_bonus": 12,
    "rsi_overbought_penalty": -5,
    "rsi_oversold_penalty": -15,
    "macd_bullish_cross_bonus": 15,
    "macd_bearish_cross_penalty": -15,
    "macd_strengthen_bonus": 7,
    "macd_weaken_penalty": -7,
    "price_above_sma50_bonus": 8,
    "price_above_sma200_bonus": 8,
    "price_below_sma50_penalty": -10,
    "golden_cross_bonus": 5,
    "adx_strong_bonus": 5,
    "supertrend_bullish_bonus": 6,
    "sar_bullish_bonus": 4,
    "near_52w_high_bonus": 8,
    "far_from_52w_high_penalty": -8,
    "volume_spike_up_bonus": 20,
    "volume_spike_down_penalty": -20,
    "obv_rising_bonus": 12,
    "obv_falling_penalty": -8,
    "mfi_bullish_bonus": 10,
    "mfi_overbought_penalty": -5,
    "cmf_positive_bonus": 10,
    "cmf_negative_penalty": -10,
    "_note": "Fine-tune every scoring bonus/penalty individually."
  },
  "data": {
    "history_period": "6mo",
    "history_interval": "1d",
    "min_data_points": 30,
    "_note": "Period options: 1mo 3mo 6mo 1y 2y 5y. Interval: 1d 1wk 1mo"
  },
  "output": {
    "top_picks_count": 5,
    "avoid_count": 5,
    "send_telegram": true,
    "save_google_sheets": true,
    "save_json": true,
    "json_output_dir": "./reports/",
    "_note": "Control what gets saved and sent."
  },
  "notifications": {
    "telegram_chat_id": "YOUR_CHAT_ID",
    "only_notify_if_strong_buy_count_min": 1,
    "_note": "Set telegram_chat_id from @userinfobot. Suppress empty reports with min count."
  }
}
